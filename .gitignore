# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Local MCP server config (holds a Supabase access token — never commit)
.mcp.json

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# VS Code — personal editor config
.vscode/

# macOS
.DS_Store
*.pem

# env files — never commit real values; only *.example templates are tracked.
# Basename patterns match at any depth (covers supabase/functions/.env, the
# app .env.local, form-editor/.env, etc.).
.env
.env.*
!.env.example
# Exception: form-editor's per-mode files hold ONLY a public function URL (not a
# secret) and must be committed so `vite build [--mode staging]` can read them.
!form-editor/.env.production
!form-editor/.env.staging

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Supabase CLI cache (links, version stamps — machine-local)
supabase/.temp/
