# LOCAL Edge Function secrets. Copy to `supabase/functions/.env` (gitignored)
# and fill with TEST/SANDBOX credentials, then run `npm run sb:serve`.
#
# In the cloud these are set per project with `supabase secrets set` (see
# docs/environments.md) — this file is ONLY for local `functions serve`.
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are provided by
# the local stack automatically and don't need to be set here.

# Stripe (use TEST keys locally)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
RESEND_API_KEY=re_...
REPORT_FROM_EMAIL=reports@notifyinspection.embrallc.com

# Railway report worker base URL — send-report-to-client renders the auto-send
# PDF via the worker's /api/render-internal (no trailing slash).
REPORT_WORKER_URL=https://<your-report-worker>.up.railway.app

# Google
GOOGLE_ROUTES_API_KEY=...
GEMINI_API_KEY=...

# Twilio (day-before appointment reminders + inbound C/X reply handling)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
# Exact public URL Twilio is configured to POST replies to (used to verify the
# X-Twilio-Signature). Set this to avoid gateway URL-rewrite signature mismatches.
TWILIO_WEBHOOK_URL=https://<project-ref>.supabase.co/functions/v1/appt-reminder-reply
# Set to "false" to stop auto-replying to C/X (cancel/no-op still happen).
TWILIO_AUTO_REPLY=true

# RevenueCat (use sandbox)
REVENUECAT_SECRET_API_KEY=...
RC_WEBHOOK_SECRET=...

# form-editor static host URL (local: the vite dev server or a deployed editor)
EDITOR_APP_URL=http://localhost:5173

# Comma-separated emails that bypass the subscription gate (dev convenience)
DEV_BYPASS_EMAILS=dev@zuba.test
