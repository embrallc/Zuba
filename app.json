{
  "expo": {
    "name": "Zanbi",
    "slug": "ClientManagment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clientmanagment",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": ""
      },
      "bundleIdentifier": "com.embrallc.ClientManagment",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCalendarsFullAccessUsageDescription": "Allow Zanbi to view your calendars and add your scheduled inspections to your calendar.",
        "NSCalendarsWriteOnlyAccessUsageDescription": "Allow Zanbi to add your scheduled inspections to your calendar."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-mail-composer",
      "@react-native-community/datetimepicker",
      "expo-location",
      "expo-image-picker",
      "expo-camera",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Zanbi to access your photos to organize inspection photos into an album.",
          "savePhotosPermission": "Allow Zanbi to save inspection photos to your device.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5C5CE8",
          "defaultChannel": "upcoming-appt"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Zanbi to view your calendars and add your scheduled inspections to your calendar."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "984033e9-55d5-48cd-bf36-c1737cbe275f"
      }
    }
  }
}
