{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_ENV": "development" }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": { "EXPO_PUBLIC_ENV": "preview" }
    },
    "preview-testflight": {
      "extends": "preview",
      "distribution": "store",
      "autoIncrement": true
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": { "EXPO_PUBLIC_ENV": "production" }
    }
  },
  "submit": {
    "preview-testflight": {},
    "production": {}
  }
}
