# Copy to .env for local runs. In Cloud Run, set these as service env vars /
# secrets — NEVER commit real values.

# Supabase project URL.
SUPABASE_URL=https://wwspvjsnkkgdziixbeei.supabase.co

# NEW-format service-role key (sb_secret_...). Bypasses RLS. Server-only.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME

# Storage bucket for report PDFs (matches the app / generate-report).
REPORT_BUCKET=inspection-reports

# Signed-URL lifetime in seconds (default 7 days).
SIGNED_URL_TTL=604800

# Local port (Cloud Run sets PORT automatically).
PORT=8080
