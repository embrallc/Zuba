# ─────────────────────────────────────────────────────────────────────────────
# App-side PUBLIC config. These are EXPO_PUBLIC_* — they ship inside the app
# bundle, so they are NOT secrets (the Supabase key here is the publishable/anon
# key, never the service-role key).
#
# LOCAL DEV: copy this file to `.env.local` (gitignored) and point it at your
# local Supabase stack from `supabase start`. Use your machine's LAN IP, NOT
# localhost/127.0.0.1, so a physical device on the same network can reach it.
#
# STAGING / PRODUCTION: these values are NOT read from a file for EAS builds —
# they come from EAS Environment Variables scoped to the `preview` (staging) and
# `production` environments. See docs/environments.md.
# ─────────────────────────────────────────────────────────────────────────────

# Local Supabase API URL (from `supabase start`; replace with your LAN IP).
EXPO_PUBLIC_SUPABASE_URL=http://192.168.1.100:54321

# Local anon/publishable key (printed by `supabase start`).
EXPO_PUBLIC_SUPABASE_KEY=your-local-anon-key

# Cloud Run / Railway report worker. Optional locally — if unset, the in-app
# "Cloud report" path is simply hidden. Point at a local worker or your dev
# worker if you want to exercise it.
# EXPO_PUBLIC_REPORT_WORKER_URL=http://192.168.1.100:8080
