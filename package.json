    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.1.8",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.105.4",
    "dayjs": "^1.11.20",
    "expo": "~54.0.33",
    "expo-calendar": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
