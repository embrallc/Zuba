# form-editor build config. The ONLY var: the form-editor edge function URL it
# calls. This is a public URL, not a secret. Vite exposes vars prefixed VITE_.
#
# Per-environment values live in committed per-mode files read by Vite:
#   .env.production  →  used by `vite build`            (prod form-editor fn)
#   .env.staging     →  used by `vite build --mode staging`
#
# For a one-off local build against a custom backend, set VITE_API_BASE here in
# a (gitignored) .env or .env.local.
VITE_API_BASE=https://<project-ref>.supabase.co/functions/v1/form-editor
